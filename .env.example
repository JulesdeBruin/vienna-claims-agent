# Database
DATABASE_URL=sqlite:///claims.db

# Company info (used in claim forms)
COMPANY_NAME="Acme Logistics GmbH"
COMPANY_ADDRESS="Mariahilfer Straße 100, 1060 Wien, Austria"
COMPANY_EMAIL=claims@acme-logistics.at
COMPANY_PHONE="+43 1 555 1234"
COMPANY_CONTACT_PERSON="Max Mustermann"

# IMAP (email ingestion — leave empty to disable)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_PROCESSED_FOLDER=Processed
IMAP_USE_SSL=true

# SMTP (notifications — leave empty to use console logging)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=

# Scheduler (daily pipeline run time, local timezone)
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

# LLM (OpenRouter — free models available)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# BrowserBase (headless browser for carrier tracking pages)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Web dashboard
WEB_HOST=0.0.0.0
WEB_PORT=8000

# Ingestion
CSV_WATCH_DIR=import
